@page
@model IndexModel
<!DOCTYPE html>
<html>
<head>
    <title>Twisted Elliptic Block Volume Calculator</title>
</head>
<body>
    <h2>Volume Calculator: Twisted Elliptic Block</h2>

    <form method="post">
        <label>a (radius X):</label>
        <input type="number" step="any" name="A" required /><br/>

        <label>b (radius Y):</label>
        <input type="number" step="any" name="B" required /><br/>

        <label>Height (h):</label>
        <input type="number" step="any" name="H" required /><br/>

        <label>Twist (radians):</label>
        <input type="number" step="any" name="Twist" required /><br/>

        <button type="submit">Calculate</button>
    </form>

    @if (Model.Volume > 0)
    {
        <h3>Volume: @Model.Volume</h3>
    }
</body>
</html>